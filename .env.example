# Environment Variables for Gerador de Orçamentos Fase Esporte

# Neon DB Connection Strings
# DATABASE_URL is the pooled connection (recommended for queries and serverless APIs)
# Format: postgresql://[user]:[password]@[neon_host]/[database]?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://user:password@ep-host.region.pooler.neon.tech/orcamentofase?sslmode=require"

# DIRECT_URL is the direct connection (required for Prisma migrations)
# Format: postgresql://[user]:[password]@[neon_host]/[database]?sslmode=require
DIRECT_URL="postgresql://user:password@ep-host.region.neon.tech/orcamentofase?sslmode=require"

# Auth — senha compartilhada da equipe de vendas (altere antes de subir para produção)
APP_PASSWORD="fase2024"

# Segredo para assinar o token de sessão — use uma string longa e aleatória
APP_SECRET="troque-por-string-secreta-aleatoria-longa"
